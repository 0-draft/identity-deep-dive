---
import type { Candidate } from "../lib/tracks";

interface Props {
  candidates: Candidate[];
}
const { candidates } = Astro.props;
---

{candidates.length === 0 ? (
  <p class="text-sm text-slate-500">No candidates above threshold.</p>
) : (
  <ol class="space-y-3">
    {candidates.map((c, i) => (
      <li class="rounded-lg border border-slate-200 bg-white p-4 hover:border-blue-300 transition">
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-start gap-3 min-w-0">
            <span class="inline-flex shrink-0 w-7 h-7 items-center justify-center rounded-full bg-slate-100 text-slate-600 text-xs font-semibold">
              {i + 1}
            </span>
            <div class="min-w-0">
              <div class="font-semibold text-slate-900 text-sm leading-snug break-words">
                {c.url ? (
                  <a class="hover:text-blue-600" href={c.url} target="_blank" rel="noreferrer">
                    {c.title}
                  </a>
                ) : (
                  c.title
                )}
              </div>
              {(c.draft_name || c.repo) && (
                <div class="mt-0.5 text-xs text-slate-500 font-mono">
                  {c.draft_name ?? c.repo}
                </div>
              )}
              {(c.reasons?.length || c.rationales?.length || c.evidence?.length) ? (
                <ul class="mt-2 flex flex-wrap gap-1.5">
                  {(c.reasons ?? c.rationales ?? c.evidence ?? []).map((r) => (
                    <li class="text-[11px] px-2 py-0.5 rounded-full bg-slate-100 text-slate-600">
                      {r}
                    </li>
                  ))}
                </ul>
              ) : null}
              {c.state_labels?.length ? (
                <ul class="mt-2 flex flex-wrap gap-1.5">
                  {c.state_labels.map((s) => (
                    <li class="text-[11px] px-2 py-0.5 rounded-full bg-blue-50 text-blue-700 border border-blue-100">
                      {s}
                    </li>
                  ))}
                </ul>
              ) : null}
            </div>
          </div>
          <div class="shrink-0 text-right">
            <div class="text-xl font-bold text-slate-900 tabular-nums">{c.score}</div>
            <div class="text-[10px] uppercase tracking-wider text-slate-400">score</div>
          </div>
        </div>
      </li>
    ))}
  </ol>
)}
