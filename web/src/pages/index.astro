---
import Layout from "../layouts/Layout.astro";
import { TRACKS, summary } from "../lib/tracks";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const summaries = TRACKS.map((t) => summary(t.id));
---

<Layout title="Identity Deep Dive">
  <section class="mb-12">
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight text-slate-900">
      Identity Deep Dive
    </h1>
    <p class="mt-3 max-w-2xl text-slate-600 leading-relaxed">
      Continuously monitors identity and security standards bodies. Each track
      collects, normalizes, and scores activity, then publishes daily and
      weekly Markdown reports.
    </p>
  </section>

  <section>
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="text-lg font-semibold text-slate-900">Tracks</h2>
      <span class="text-xs text-slate-500">Latest snapshot per track</span>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {summaries.map((s) => (
        <a
          href={`${base}/${s.id}/`}
          class="group block rounded-xl border border-slate-200 bg-white p-5 hover:border-blue-400 hover:shadow-sm transition"
        >
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-semibold text-slate-900 text-base group-hover:text-blue-600">
                {s.meta.name}
              </h3>
              <p class="mt-1 text-xs text-slate-500">{s.meta.org}</p>
            </div>
            {s.topScore != null && (
              <div class="text-right shrink-0">
                <div class="text-lg font-bold text-slate-900 tabular-nums">{s.topScore}</div>
                <div class="text-[10px] uppercase tracking-wider text-slate-400">top score</div>
              </div>
            )}
          </div>
          <p class="mt-3 text-sm text-slate-600 leading-snug">{s.meta.scope}</p>
          <dl class="mt-4 grid grid-cols-3 gap-2 text-xs">
            <div>
              <dt class="text-slate-400 uppercase tracking-wider text-[10px]">Daily</dt>
              <dd class="font-mono text-slate-700">{s.dailyName ?? "—"}</dd>
            </div>
            <div>
              <dt class="text-slate-400 uppercase tracking-wider text-[10px]">Weekly</dt>
              <dd class="font-mono text-slate-700">{s.weeklyName ?? "—"}</dd>
            </div>
            <div>
              <dt class="text-slate-400 uppercase tracking-wider text-[10px]">Candidates</dt>
              <dd class="font-mono text-slate-700">{s.candidateCount}</dd>
            </div>
          </dl>
        </a>
      ))}
    </div>
  </section>
</Layout>
