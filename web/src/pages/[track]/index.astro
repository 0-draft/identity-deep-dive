---
import Layout from "../../layouts/Layout.astro";
import CandidateList from "../../components/CandidateList.astro";
import {
  TRACKS,
  latestDaily,
  latestWeekly,
  topCandidates,
  type TrackId,
} from "../../lib/tracks";
import { renderMarkdown } from "../../lib/markdown";

export function getStaticPaths() {
  return TRACKS.map((t) => ({ params: { track: t.id } }));
}

const { track } = Astro.params;
const trackId = track as TrackId;
const meta = TRACKS.find((t) => t.id === trackId)!;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const daily = latestDaily(trackId);
const weekly = latestWeekly(trackId);
const candidates = topCandidates(trackId, 12);
---

<Layout title={`${meta.name} — Identity Deep Dive`}>
  <nav class="text-xs text-slate-500 mb-4">
    <a class="hover:text-blue-600" href={`${base}/`}>Overview</a>
    <span class="mx-1.5">/</span>
    <span>{meta.name}</span>
  </nav>

  <header class="mb-10">
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight text-slate-900">
          {meta.name}
        </h1>
        <p class="mt-2 text-slate-600">{meta.scope}</p>
      </div>
      <div class="flex flex-wrap gap-2 text-xs">
        {meta.href && (
          <a
            class="px-3 py-1.5 rounded-md bg-slate-100 text-slate-700 hover:bg-slate-200"
            href={meta.href}
            target="_blank"
            rel="noreferrer"
          >
            ↗ Source
          </a>
        )}
        <a
          class="px-3 py-1.5 rounded-md bg-slate-100 text-slate-700 hover:bg-slate-200"
          href={`https://github.com/0-draft/identity-deep-dive/tree/main/tracks/${trackId}`}
          target="_blank"
          rel="noreferrer"
        >
          ↗ Track repo
        </a>
      </div>
    </div>
  </header>

  <div class="grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-8">
      {daily && (
        <section class="rounded-xl border border-slate-200 bg-white p-6 sm:p-8">
          <div class="flex items-baseline justify-between gap-3 mb-4">
            <h2 class="text-base font-semibold text-slate-900">
              Daily Report
              <span class="ml-2 text-xs font-mono font-normal text-slate-500">{daily.name.replace(/\.md$/, "")}</span>
            </h2>
          </div>
          <article class="prose-report" set:html={renderMarkdown(daily.body)} />
        </section>
      )}

      {weekly && (
        <section class="rounded-xl border border-slate-200 bg-white p-6 sm:p-8">
          <div class="flex items-baseline justify-between gap-3 mb-4">
            <h2 class="text-base font-semibold text-slate-900">
              Weekly Digest
              <span class="ml-2 text-xs font-mono font-normal text-slate-500">{weekly.name.replace(/\.md$/, "")}</span>
            </h2>
          </div>
          <article class="prose-report" set:html={renderMarkdown(weekly.body)} />
        </section>
      )}

      {!daily && !weekly && (
        <section class="rounded-xl border border-dashed border-slate-300 bg-white p-8 text-center text-sm text-slate-500">
          No reports generated yet.
        </section>
      )}
    </div>

    <aside class="space-y-6 lg:sticky lg:top-24 self-start">
      <section>
        <h2 class="text-base font-semibold text-slate-900 mb-3">Top Deep-Dive Candidates</h2>
        <CandidateList candidates={candidates} />
      </section>
    </aside>
  </div>
</Layout>
